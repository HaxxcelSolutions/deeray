# Database
DB_PASSWORD="CHANGE_ME_DB_PASS"
DATABASE_URL="postgresql://deeray:${DB_PASSWORD}@db:5432/deeray?schema=public"

# Admin Session (generate with: openssl rand -hex 32)
SESSION_SECRET="change-this-to-a-random-64-char-hex-string"

# Site
SITE_URL="https://yourdomain.com"

# Email (SMTP — optional, order confirmation will skip if unset)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@deeray.com"

# Docker Hub (required for deploy — GitHub Actions pushes here)
DOCKER_USER="your-dockerhub-username"

# Analytics (optional)
GA4_ID=""
FB_PIXEL_ID=""
